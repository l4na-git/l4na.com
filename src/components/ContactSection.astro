---
const contactLinks = [
  {
    name: "GitHub",
    href: "https://github.com",
    ariaLabel: "GitHubを開く",
    external: true,
    svgPaths: [
      'M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4',
      'M9 18c-4.51 2-5-2-7-2',
    ],
  },
  {
    name: "X",
    href: "https://x.com",
    ariaLabel: "Xを開く",
    external: true,
    svgPaths: [
      'M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z',
    ],
  },
  {
    name: "note",
    href: "https://note.com",
    ariaLabel: "noteを開く",
    external: true,
    svgPaths: [
      'M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z',
      'M14 2v4a2 2 0 0 0 2 2h4',
      'M10 9H8',
      'M16 13H8',
      'M16 17H8',
    ],
  },
  {
    name: "Email",
    href: "mailto:hello@example.com",
    ariaLabel: "メールを送る",
    external: false,
    svgPaths: [
      'm22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7',
    ],
    svgRects: [{ width: 20, height: 16, x: 2, y: 4, rx: 2 }],
  },
]
---

<section id="contact" class="py-20 px-4 md:px-8 lg:px-12">
  <div class="max-w-3xl mx-auto text-center">
    <div class="mb-6">
      <p class="text-xs font-medium text-sky-dark uppercase tracking-widest mb-2">Contact</p>
      <h2 class="text-2xl md:text-3xl font-bold text-navy">
        お問い合わせ
      </h2>
    </div>
    <p class="text-muted-foreground mb-8">お気軽にご連絡ください</p>

    <div class="flex justify-center gap-4 flex-wrap">
      {contactLinks.map((link) => (
        <a
          href={link.href}
          aria-label={link.ariaLabel}
          target={link.external ? "_blank" : undefined}
          rel={link.external ? "noopener noreferrer" : undefined}
          class="flex items-center gap-2 px-5 py-3 bg-card rounded-xl border border-border shadow-sm hover:border-sky-medium/50 hover:bg-sky-light/30 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-sky-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            {link.svgRects?.map((r) => (
              <rect width={r.width} height={r.height} x={r.x} y={r.y} rx={r.rx} />
            ))}
            {link.svgPaths.map((d) => (
              <path d={d} />
            ))}
          </svg>
          <span class="text-sm font-medium text-navy">{link.name}</span>
        </a>
      ))}
    </div>
  </div>
</section>
